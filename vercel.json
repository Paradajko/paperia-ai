{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "api/generate-pdf.ts": {
      "includeFiles": "src/assets/ria-guide-half.png",
      "memory": 1024,
      "maxDuration": 10
    }
  },
  "rewrites": [
    {
      "source": "/privacy",
      "destination": "/privacy/index.html"
    },
    {
      "source": "/terms",
      "destination": "/terms/index.html"
    },
    {
      "source": "/sk",
      "destination": "/sk/index.html"
    },
    {
      "source": "/rs",
      "destination": "/rs/index.html"
    },
    {
      "source": "/ua",
      "destination": "/ua/index.html"
    },
    {
      "source": "/bfacd551628758d4595c11f0d219fe25.txt",
      "destination": "/bfacd551628758d4595c11f0d219fe25.txt"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/send-sequence",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/cron/send-sequence",
      "schedule": "0 8 * * *"
    }
  ]
}
