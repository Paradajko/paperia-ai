{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    {
      "source": "/privacy",
      "destination": "/privacy/index.html"
    },
    {
      "source": "/terms",
      "destination": "/terms/index.html"
    },
    {
      "source": "/sk",
      "destination": "/sk/index.html"
    },
    {
      "source": "/rs",
      "destination": "/rs/index.html"
    },
    {
      "source": "/ua",
      "destination": "/ua/index.html"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/send-sequence",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/cron/send-sequence",
      "schedule": "0 8 * * *"
    }
  ]
}
